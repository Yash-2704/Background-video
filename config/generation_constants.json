  "lut_specifications": {
    "cool_authority": {
      "color_temp_shift_k": -800,
      "saturation_multiplier": 0.85,
      "lift_shadows": -0.02
    },
    "neutral": {
      "color_temp_shift_k": 0,
      "saturation_multiplier": 1.0,
      "lift_shadows": 0
    },
    "warm_tension": {
      "color_temp_shift_k": 600,
      "saturation_multiplier": 0.90,
      "lift_shadows": -0.04
    }
  },
  "dev_mode": true,
  "production_note": "Set extensions_per_clip to 4 and dev_mode to false for production"
}
